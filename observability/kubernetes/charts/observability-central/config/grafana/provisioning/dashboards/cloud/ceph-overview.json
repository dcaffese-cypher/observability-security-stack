{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Ceph cluster health, OSD status, and pool usage. Requires ceph-exporter or prometheus-ceph-exporter. Confirm metric names with the Cloud team.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Cluster Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "OK" }, "1": { "color": "orange", "index": 1, "text": "WARNING" }, "2": { "color": "red", "index": 2, "text": "ERROR" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "editorMode": "code",
          "expr": "ceph_health_status",
          "instant": true,
          "legendFormat": "Health",
          "refId": "A"
        }
      ],
      "title": "Cluster Health",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "editorMode": "code",
          "expr": "count(ceph_osd_up == 1)",
          "instant": true,
          "legendFormat": "OSDs Up",
          "refId": "A"
        }
      ],
      "title": "OSDs Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "editorMode": "code",
          "expr": "ceph_pg_degraded",
          "instant": true,
          "legendFormat": "Degraded PGs",
          "refId": "A"
        }
      ],
      "title": "Degraded Placement Groups",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "12.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "editorMode": "code",
          "expr": "ceph_pg_active",
          "instant": true,
          "legendFormat": "Active PGs",
          "refId": "A"
        }
      ],
      "title": "Active Placement Groups",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Pool Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "12.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "editorMode": "code",
          "expr": "ceph_pool_used_bytes",
          "legendFormat": "{{name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pool Used Bytes",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "pluginVersion": "12.1.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "victoria-metrics" },
          "editorMode": "code",
          "expr": "ceph_pool_max_avail",
          "legendFormat": "{{name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pool Max Available Bytes",
      "type": "timeseries"
    }
  ],
  "preload": false,
  "schemaVersion": 41,
  "tags": ["ceph", "cloud", "storage"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
