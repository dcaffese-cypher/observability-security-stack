    {
      "id": 31,
      "type": "stat",
      "title": "Pods with Restarts (last 15m)",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoria-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 4
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoria-metrics"
          },
          "expr": "count(increase(kube_pod_container_status_restarts_total[15m]) > 3) or vector(0)",
          "legendFormat": "Pods in CrashLoop",
          "instant": true
        }
      ]
    },
    {
      "id": 32,
      "type": "table",
      "title": "Top Restarting Pods (last 15m)",
      "gridPos": {
        "x": 6,
        "y": 20,
        "w": 18,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "victoria-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Restarts (15m)"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 4
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Restarts (15m)",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "victoria-metrics"
          },
          "expr": "sort_desc(increase(kube_pod_container_status_restarts_total[15m]) > 0)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "cluster": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "metrics_path": true,
              "prometheus": true,
              "prometheus_replica": true,
              "server_address": true,
              "server_port": true,
              "service": true,
              "service_instance_id": true,
              "service_name": true,
              "uid": true,
              "url_scheme": true,
              "environment": true
            },
            "renameByName": {
              "namespace": "Namespace",
              "pod": "Pod",
              "container": "Container"
            }
          }
        }
      ]
    },
